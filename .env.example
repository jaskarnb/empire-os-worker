# Required
ANTHROPIC_API_KEY=sk-ant-...
POSTIZ_API_KEY=

# Server
PORT=3001
CORS_ORIGIN=https://your-dashboard.vercel.app
POSTING_BACKEND=postiz
POSTIZ_API_URL=http://localhost:5000
POSTIZ_WEB_URL=
PUBLIC_WORKER_URL=

# Higgsfield production video generation
HIGGSFIELD_ENABLED=false
HIGGSFIELD_CLI_PATH=higgsfield
HIGGSFIELD_VIDEO_MODEL=cinematic_studio_video_v2
HIGGSFIELD_RENDER_COST_USD=0.35
HIGGSFIELD_WAIT_TIMEOUT=20m
HIGGSFIELD_WAIT_INTERVAL=5s
HIGGSFIELD_TIMEOUT_MS=1500000
HIGGSFIELD_ASPECT_RATIO_PARAM=aspect_ratio
HIGGSFIELD_ASPECT_RATIO=9:16
HIGGSFIELD_GENRE=horror
HIGGSFIELD_MODE=pro
HIGGSFIELD_SOUND=on
HIGGSFIELD_DURATION=12
HIGGSFIELD_RESOLUTION=

# Budget controls
DAILY_SPEND_LIMIT_USD=10

# Debug-only local renderer. Never enable for production posting.
HIGGSFIELD_ALLOW_LOCAL_DEBUG=false
AUDIO_DIR=./output/audio
VIDEO_DIR=./output/video
DEFAULT_TTS_VOICE=en-US-AriaNeural
DARK_TTS_VOICE=en-US-AriaNeural
HORROR_TTS_VOICE=en-US-GuyNeural
BRAINROT_TTS_VOICE=en-US-JennyNeural
KIDS_TTS_VOICE=en-US-AnaNeural

# Automation
AUTO_STANDUP=false
STANDUP_HOUR=7
WEBHOOK_URL=
CHROME_EXECUTABLE_PATH=/usr/bin/chromium

# Slack notifications
SLACK_NOTIFICATIONS_ENABLED=false
SLACK_WEBHOOK_URL=
SLACK_APP_NAME=Empire OS
SLACK_NOTIFY_LEVELS=urgent,warning,success,daily
SLACK_NOTIFY_OK_WATCHERS=false
